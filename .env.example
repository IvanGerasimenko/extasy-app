# Copy to .env and fill from Google Cloud Console:
# https://console.cloud.google.com/apis/credentials
# Supabase project settings -> API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key
EXPO_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=your_public_vapid_key

# OAuth client type: Web application
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
# Must match an Authorized redirect URI in Google Cloud Console.
# Local web example: http://localhost:8082
EXPO_PUBLIC_GOOGLE_WEB_REDIRECT_URI=http://localhost:8082/auth/callback

# OAuth client type: iOS
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id.apps.googleusercontent.com

# OAuth client type: Android
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=your_google_android_client_id.apps.googleusercontent.com
